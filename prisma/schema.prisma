generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleCategory {
  SEDAN
  SUV
  MPV
  TEMPO_TRAVELLER
  URBANIA
}

enum TripType {
  ONE_DAY
  MULTI_DAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum AdminRole {
  SUPER_ADMIN
  MANAGER
  DISPATCHER
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(MANAGER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vehicle {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  category      VehicleCategory
  tagline       String          @default("")
  description   String          @default("")
  seats         Int
  luggage       Int
  ac            Boolean         @default(true)
  fuel          String          @default("Diesel")
  basePrice     Int
  perDayPrice   Int
  extraKmRate   Int
  driverBata    Int             @default(400)
  illustration  String          @default("sedan")
  features      String[]
  examples      String          @default("")
  images        VehicleImage[]
  popular       Boolean         @default(false)
  available     Boolean         @default(true)
  sortOrder     Int             @default(0)
  bookings      Booking[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([category, available])
}

model VehicleImage {
  id        String  @id @default(cuid())
  url       String
  alt       String  @default("")
  isPrimary Boolean @default(false)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String
}

model PricingConfig {
  id                 String   @id @default("global")
  oneDayIncludedKm   Int      @default(80)
  multiDayIncludedKm Int      @default(100)
  bookingAmount      Int      @default(199)
  nightChargePct     Int      @default(10)
  holidayChargePct   Int      @default(10)
  gstPct             Int      @default(5)
  notes              String   @default("Additional KM charges applicable. Parking & toll extra. Night charges if applicable.")
  updatedAt          DateTime @updatedAt
}

model SeasonPricing {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  markupPct Int      @default(10)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Customer {
  id        String    @id @default(cuid())
  phone     String    @unique
  name      String
  email     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Driver {
  id          String    @id @default(cuid())
  name        String
  phone       String    @unique
  licenseNo   String
  vehicleReg  String    @default("")
  rating      Float     @default(5)
  active      Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id            String        @id @default(cuid())
  bookingCode   String        @unique
  tripType      TripType
  days          Int           @default(1)
  passengers    Int
  pickup        String
  destination   String
  pickupDate    DateTime
  pickupTime    String
  name          String
  phone         String
  email         String?
  notes         String?
  status        BookingStatus @default(PENDING)
  estimateTotal Int
  bookingAmount Int           @default(199)
  includedKm    Int
  extraKmRate   Int
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  vehicleId     String
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerId    String?
  driver        Driver?       @relation(fields: [driverId], references: [id])
  driverId      String?
  payment       Payment?
  phoneVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, pickupDate])
  @@index([phone])
}

model Payment {
  id               String        @id @default(cuid())
  booking          Booking       @relation(fields: [bookingId], references: [id])
  bookingId        String        @unique
  razorpayOrderId  String        @unique
  razorpayPayId    String?
  amount           Int
  currency         String        @default("INR")
  status           PaymentStatus @default(CREATED)
  method           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("")
  location  String   @default("")
  rating    Int      @default(5)
  text      String
  trip      String   @default("")
  videoUrl  String?
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TourPackage {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  days        Int
  priceFrom   Int
  summary     String
  itinerary   Json
  coverImage  String   @default("")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String    @default("")
  content     String    @default("")
  coverImage  String    @default("")
  published   Boolean   @default(false)
  publishedAt DateTime?
  seoTitle    String    @default("")
  seoDesc     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CmsSection {
  id        String   @id @default(cuid())
  page      String
  key       String
  content   Json
  updatedAt DateTime @updatedAt

  @@unique([page, key])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
